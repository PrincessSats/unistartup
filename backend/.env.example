# ============================================================
# HackNet Platform - Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ============================================================
# Database Configuration (Yandex Cloud PostgreSQL)
# ============================================================
DB_HOST=db-hacknetrw.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=hacknet
DB_USER=hacknet_user
DB_PASSWORD=your_secure_password_here

# ============================================================
# JWT Authentication
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your_super_secret_key_min_32_chars_here

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=48

# Refresh token cookie settings
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/
REFRESH_TOKEN_COOKIE_DOMAIN=.hacknet.tech
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# ============================================================
# CORS Configuration
# ============================================================
CORS_ALLOW_ORIGINS=https://hacknet.tech,https://www.hacknet.tech,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=^https://[a-zA-Z0-9-]+\.(website|storage)\.yandexcloud\.net$
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Auth-Token

# ============================================================
# Yandex OAuth Configuration
# ============================================================
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_OAUTH_SCOPES=login:email,login:info,login:avatar

# ============================================================
# GitHub OAuth Configuration
# ============================================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_SCOPES=read:user,user:email

# ============================================================
# Telegram OIDC Configuration
# ============================================================
TELEGRAM_BOT_API_TOKEN=your_telegram_bot_token
TELEGRAM_CLIENT_ID=your_telegram_client_id
TELEGRAM_CLIENT_SECRET=your_telegram_client_secret
TELEGRAM_OAUTH_SCOPES=openid,profile

# ============================================================
# Email Configuration (Yandex SMTP)
# ============================================================
YANDEX_MAIL_LOGIN=noreply@hacknet.tech
YANDEX_MAIL_PASSWORD=your_app_password_here
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_FROM=noreply@hacknet.tech
MAGIC_LINK_TTL_HOURS=24

# ============================================================
# Yandex Cloud Object Storage (S3-compatible)
# ============================================================
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=hacknet-storage
S3_TASK_BUCKET_NAME=hacknet-tasks

# ============================================================
# Yandex Cloud LLM Configuration
# ============================================================
YANDEX_CLOUD_API_KEY=your_yandex_cloud_api_key
YANDEX_CLOUD_FOLDER=your_folder_id
YANDEX_REASONING_EFFORT=high

# ============================================================
# AI Generator Settings (GRPO Pipeline)
# ============================================================
AI_GEN_NUM_VARIANTS=5
AI_GEN_MAX_RETRIES=2
AI_GEN_MIN_REWARD_THRESHOLD=0.6
AI_GEN_BASE_TEMPERATURE=0.7
AI_GEN_TEMPERATURE_STEP=0.1
AI_GEN_RAG_CONTEXT_LIMIT=5
AI_GEN_EMBEDDING_DIMENSION=256

# ============================================================
# Security Settings
# ============================================================

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=true
ENABLE_PASSWORD_BREACH_CHECK=false

# Redis (Yandex Managed Redis) - for distributed rate limiting
REDIS_HOST=rc1a-your-redis.mdb.yandexcloud.net
REDIS_PORT=6371
REDIS_PASSWORD=your_redis_password

# Security Headers
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://api.hacknet.tech https://storage.yandexcloud.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
CSP_REPORT_URI=

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# ============================================================
# Application Settings
# ============================================================
SQL_ECHO=false
RUN_STARTUP_DB_MAINTENANCE=false
LOG_SLOW_REQUESTS=true
SLOW_REQUEST_THRESHOLD_MS=1000

# ============================================================
# Frontend API Configuration (for build time)
# ============================================================
# REACT_APP_API_BASE_URL=https://api.hacknet.tech
# REACT_APP_API_TIMEOUT_MS=15000
# REACT_APP_ADMIN_NVD_TIMEOUT_MS=120000
# REACT_APP_AUTH_LOGIN_TIMEOUT_MS=10000

# ============================================================
# Backend Callback Base URL (OAuth)
# ============================================================
# For production:
BACKEND_CALLBACK_BASE_URL=https://api.hacknet.tech
# For local development:
# BACKEND_CALLBACK_BASE_URL=http://localhost:8000

# ============================================================
# Feature Flags
# ============================================================
ENABLE_USER_VARIANTS=true
ENABLE_AI_GENERATION=true
ENABLE_KNOWLEDGE_BASE=true
